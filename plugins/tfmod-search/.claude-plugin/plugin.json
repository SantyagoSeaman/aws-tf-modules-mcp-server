{
  "name": "tfmod-search",
  "displayName": "TFModSearch",
  "version": "0.22.0",
  "description": "Search current Terraform AWS module documentation before writing Terraform — hybrid keyword + BM25 + semantic search over the community terraform-aws-modules catalog.",
  "author": {
    "name": "Alexander Makeev",
    "url": "https://github.com/SantyagoSeaman"
  },
  "homepage": "https://github.com/SantyagoSeaman/tfmodsearch",
  "repository": "https://github.com/SantyagoSeaman/tfmodsearch",
  "license": "MIT",
  "keywords": ["terraform", "aws", "mcp", "search", "infrastructure"],
  "agents": [
    "./agents/tf-log-analyst.md",
    "./agents/tf-diff-reviewer.md"
  ],
  "mcpServers": {
    "tfmod-search": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bin/tfmodsearch_launch.py"]
    }
  }
}
